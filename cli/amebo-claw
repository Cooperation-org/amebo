#!/usr/bin/env python3
"""
amebo-claw — minimal CLI for managing amebo claws from a voice/Claude session.

A claw is amebo's computational unit. This CLI hits amebo's HTTP API:
  POST /api/goals/         create a claw
  GET  /api/goals/         list claws

See arch_notes.md ("Goals and claws") in the abra repo for the contract.

Auth: an X-API-Key read from $AMEBO_CLI_KEY_FILE (default ~/.amebo/cli-key).
The key is a plain string; the server stores its SHA-256 in `api_keys`.

API base: $AMEBO_CLI_URL (default http://127.0.0.1:8000).

Usage:
  amebo-claw create --title "..." [--description "..."] [--cron "0 9 * * 1"]
                    [--notify slack:#channel] [--store URL] [--store URL]
  amebo-claw list   [--status pending|active|completed|failed|paused]
                    [--limit 20]
  amebo-claw show <claw-id>
"""

import argparse
import json
import os
import sys
import urllib.error
import urllib.request
from pathlib import Path


def _api_base() -> str:
    return os.environ.get("AMEBO_CLI_URL", "http://127.0.0.1:8000").rstrip("/")


def _api_key() -> str:
    path = Path(os.environ.get("AMEBO_CLI_KEY_FILE", "~/.amebo/cli-key")).expanduser()
    if not path.exists():
        sys.stderr.write(
            f"no api key file at {path}. "
            f"set AMEBO_CLI_KEY_FILE or create the file (chmod 600).\n"
        )
        sys.exit(2)
    key = path.read_text().strip()
    if not key:
        sys.stderr.write(f"api key file at {path} is empty.\n")
        sys.exit(2)
    return key


def _req(method: str, path: str, body: dict | None = None) -> tuple[int, dict | list | None]:
    url = f"{_api_base()}{path}"
    data = json.dumps(body).encode() if body is not None else None
    req = urllib.request.Request(
        url,
        data=data,
        method=method,
        headers={
            "X-API-Key": _api_key(),
            "Accept": "application/json",
            **({"Content-Type": "application/json"} if data else {}),
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as r:
            return r.status, json.loads(r.read() or b"null")
    except urllib.error.HTTPError as e:
        msg = e.read().decode("utf-8", errors="replace")
        try:
            parsed = json.loads(msg)
        except Exception:
            parsed = {"detail": msg}
        return e.code, parsed


def _short_id(s: str, n: int = 8) -> str:
    return s[:n] if len(s) > n else s


def cmd_create(args: argparse.Namespace) -> int:
    body: dict = {"title": args.title}
    if args.description:
        body["description"] = args.description
    if args.cron:
        body["trigger_config"] = {"cron": args.cron}
    if args.notify:
        body["notify_channel"] = args.notify
    config: dict = {}
    if args.store:
        config["context_stores"] = list(args.store)
    if args.provenance:
        try:
            config["provenance"] = json.loads(args.provenance)
        except json.JSONDecodeError as e:
            sys.stderr.write(f"--provenance is not valid JSON: {e}\n")
            return 2
    if config:
        body["config"] = config

    status, payload = _req("POST", "/api/goals/", body)
    if status == 201 and isinstance(payload, dict):
        print(f"created  {payload['id']}  {payload.get('status', '?')}  {payload['title']}")
        return 0
    sys.stderr.write(f"create failed ({status}): {json.dumps(payload)}\n")
    return 1


def cmd_list(args: argparse.Namespace) -> int:
    path = f"/api/goals/?limit={args.limit}"
    if args.status:
        path += f"&status={args.status}"
    status, payload = _req("GET", path)
    if status != 200 or not isinstance(payload, list):
        sys.stderr.write(f"list failed ({status}): {json.dumps(payload)}\n")
        return 1
    if not payload:
        print("(no claws)")
        return 0
    # Compact tabular output: short id, status, updated/created date, title.
    for g in payload:
        when = (g.get("updated_at") or g.get("created_at") or "")[:10]
        title = (g.get("title") or "").replace("\n", " ")
        if len(title) > 70:
            title = title[:67] + "..."
        print(f"{_short_id(g['id'])}  {g.get('status','?'):<10}  {when}  {title}")
    return 0


def cmd_show(args: argparse.Namespace) -> int:
    status, payload = _req("GET", f"/api/goals/{args.id}")
    if status != 200 or not isinstance(payload, dict):
        sys.stderr.write(f"show failed ({status}): {json.dumps(payload)}\n")
        return 1
    print(json.dumps(payload, indent=2))
    return 0


def main() -> int:
    p = argparse.ArgumentParser(prog="amebo-claw", description=__doc__,
                                formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = p.add_subparsers(dest="cmd", required=True)

    c = sub.add_parser("create", help="create a claw")
    c.add_argument("--title", required=True)
    c.add_argument("--description")
    c.add_argument("--cron", help="cron schedule; blank means manual dispatch only")
    c.add_argument("--notify", help='notify channel, e.g. "slack:#standup"')
    c.add_argument("--store", action="append", default=[],
                   help="context-store URL; repeat for multiple")
    c.add_argument("--provenance", help="JSON blob recording who created this and how")
    c.set_defaults(func=cmd_create)

    l = sub.add_parser("list", help="list claws")
    l.add_argument("--status", choices=["pending", "active", "completed", "failed", "paused"])
    l.add_argument("--limit", type=int, default=20)
    l.set_defaults(func=cmd_list)

    s = sub.add_parser("show", help="show full claw payload")
    s.add_argument("id")
    s.set_defaults(func=cmd_show)

    args = p.parse_args()
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
