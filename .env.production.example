# ==========================================
# AMEBO - PRODUCTION ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env.production and fill in your values

# ==========================================
# DATABASE
# ==========================================
# Database name: amebo
# User: postgres
POSTGRES_PASSWORD=your-secure-postgres-password

# ==========================================
# SLACK API CREDENTIALS
# ==========================================
# Get from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-production-bot-token
SLACK_APP_TOKEN=xapp-your-production-app-token
SLACK_SIGNING_SECRET=your-production-signing-secret

# ==========================================
# AI CONFIGURATION
# ==========================================
ANTHROPIC_API_KEY=your-production-anthropic-api-key

# ==========================================
# SECURITY
# ==========================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-32-character-encryption-key
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-production-jwt-secret-key

# ==========================================
# APPLICATION SETTINGS
# ==========================================
DEBUG=false
LOG_LEVEL=INFO

# ==========================================
# CORS
# ==========================================
# Comma-separated browser origins allowed to call the API cross-origin.
# Credentials (the HttpOnly session cookie) are allowed, so this list is an
# auth boundary: list explicit origins only, never "*".
# Cohort dash deployment (workers.vc dashboard embeds — see PLAN-cohort-dash.md):
CORS_ORIGINS=https://workers.vc,https://www.workers.vc,https://amebo.workers.vc

# Origins the OIDC login flow may redirect to after login via ?next=
# (login chaining from the dash sign-in chip). Same-site paths and the
# FRONTEND_URL origin are always allowed; anything else must be listed here.
OIDC_NEXT_ALLOWED_ORIGINS=https://workers.vc,https://www.workers.vc

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
# For production, use a proper SMTP service (SendGrid, AWS SES, etc.)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-smtp-password
FROM_EMAIL=noreply@your-domain.com

# ==========================================
# FRONTEND
# ==========================================
# Use your backend API subdomain
NEXT_PUBLIC_API_URL=https://api.amebo.linkedtrust.us
# Or for development without SSL: http://api.amebo.linkedtrust.us
NEXT_PUBLIC_APP_NAME=Amebo - AI Workspace Intelligence
